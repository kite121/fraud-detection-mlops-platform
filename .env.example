# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# MinIO (object storage)
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_SECURE=false

# MLflow (experiment tracking – Sprint 2)
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=fraud-detection-training
MLFLOW_ARTIFACTS_BUCKET=mlflow-artifacts

# These mirror MinIO credentials so MLflow can write artifacts to MinIO via S3 API
AWS_ACCESS_KEY_ID="${MINIO_ROOT_USER}"
AWS_SECRET_ACCESS_KEY="${MINIO_ROOT_PASSWORD}"
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# RabbitMQ:  Sprint 3 (Task 1)
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=
RABBITMQ_URL=amqp://guest:@rabbitmq:5672//

# Celery (uses RabbitMQ as broker)
CELERY_BROKER_URL=amqp://guest:@rabbitmq:5672//
CELERY_RESULT_BACKEND=rpc://
